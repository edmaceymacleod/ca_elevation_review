{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/edmaceymacleod/ca_elevation_review/schemas/verdict_report.schema.json",
  "title": "Verdict Report",
  "description": "Structured engine output: per-device verdicts with deltas and confidence, plus a summary. Consumed by the Revit add-in for write-back and by the report renderer.",
  "type": "object",
  "required": ["schema_version", "project_id", "device_results", "summary"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "project_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "engine_version": { "type": "string" },
    "units": { "type": "string", "enum": ["feet", "meters"] },
    "device_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/device_result" }
    },
    "summary": {
      "type": "object",
      "required": ["total", "pass", "flag", "absent", "type_mismatch"],
      "additionalProperties": false,
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "pass": { "type": "integer", "minimum": 0 },
        "flag": { "type": "integer", "minimum": 0 },
        "absent": { "type": "integer", "minimum": 0 },
        "type_mismatch": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "device_result": {
      "type": "object",
      "required": ["device_id", "verdict", "confidence"],
      "additionalProperties": false,
      "properties": {
        "device_id": { "type": "string" },
        "family": { "type": "string" },
        "type": { "type": "string" },
        "verdict": { "type": "string", "enum": ["pass", "flag", "absent", "type_mismatch"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "matched_shot_id": { "type": ["string", "null"] },
        "identity_confirmed": { "type": "boolean", "default": false },
        "deltas": {
          "type": "object",
          "additionalProperties": false,
          "description": "Measured deviations between expected and observed. null where not measurable from this capture.",
          "properties": {
            "position": { "type": ["number", "null"], "description": "Euclidean position delta, project units." },
            "mounting_height": { "type": ["number", "null"] },
            "orientation": { "type": ["number", "null"], "description": "Facing angle delta, degrees." }
          }
        },
        "approximate": {
          "type": "boolean",
          "default": false,
          "description": "True when geometry was derived without metric LiDAR or from a protruding/occluded device."
        },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
